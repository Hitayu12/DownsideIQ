# =====================================================================
# DownsideIQ environment variables
# Copy to `.env` and fill in. Missing optional keys must NEVER break the
# pipeline — the system falls back to heuristics / mocks where possible.
# =====================================================================

# --- News search (live event overlay) ---
TAVILY_API_KEY=

# --- Structured news scoring (LLM). Heuristic fallback used if absent. ---
GEMINI_API_KEY=
# Model for news scoring. gemini-2.5-flash works on the free tier;
# gemini-2.0-flash returned a 0 free-tier quota in testing. Optional override.
GEMINI_MODEL=gemini-2.5-flash

# --- Fundamentals / earnings / company context ---
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

# --- Storage / infra ---
DATABASE_URL=sqlite:///downsideiq.db
# For Postgres (prod): postgresql+psycopg://user:pass@host:5432/downsideiq
REDIS_URL=redis://localhost:6379/0
# Dashboard -> API base URL (compose sets http://api:8000)
API_BASE=http://localhost:8000
# Set true to run Celery tasks inline without Redis (local dev only)
CELERY_EAGER=false

# --- Defaults ---
DEFAULT_TICKER=NVDA
DEFAULT_HORIZON=24h
DEFAULT_BAR_SIZE=1d

# --- News scoring provider preference: gemini | heuristic ---
NEWS_SCORER=gemini

# --- Trading safety (DO NOT enable live trading) ---
PAPER_TRADING_MODE=true
LIVE_TRADING_ENABLED=false
